# Copy this file to .env and fill in only the provider you use.
# Do not commit .env.

# Default is none, which uses local retrieval and does not need an API key.
# Set KB_PROVIDER=deepseek, openai, or openai-compatible when you want model answers.
KB_PROVIDER=none

# DeepSeek
DEEPSEEK_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Generic OpenAI-compatible service
KB_API_KEY=
KB_BASE_URL=
KB_MODEL=
